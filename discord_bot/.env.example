# Discord bot token (from https://discord.com/developers/applications)
DISCORD_TOKEN=your_discord_bot_token_here

# Name of the Discord channel where the leaderboard is posted
LEADERBOARD_CHANNEL=referral-leaderboard

# Number of referrals needed to earn the reward (default: 8)
REFERRAL_THRESHOLD=8

# The promo code sent to members who hit the threshold
PROMO_CODE=HALFOFF

# Path to the JSON file used to persist referral counts
DATA_FILE=referral_data.json
