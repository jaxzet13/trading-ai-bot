# BetLab AI Discord Bot — Environment Variables
# Copy this file to .env and fill in your values

# Required — Discord bot credentials
# Get from: discord.com/developers/applications > Your App > Bot > Token
DISCORD_TOKEN=your_discord_bot_token_here

# Required — Your Discord server ID
# How to get: Right-click your server icon > Copy Server ID (enable Developer Mode first)
DISCORD_GUILD_ID=123456789012345678

# Required — The #picks channel where the bot posts daily picks
# How to get: Right-click the channel > Copy Channel ID
PICKS_CHANNEL_ID=123456789012345678

# Required — The role ID for premium/paid members
# How to get: Server Settings > Roles > click role > Copy Role ID
PREMIUM_ROLE_ID=123456789012345678

# Optional — Daily picks schedule (default: 9:00 AM)
PICKS_SCHEDULE_HOUR=9
PICKS_SCHEDULE_MINUTE=0
PICKS_TIMEZONE=America/New_York

# Optional — How many free picks per day for non-premium members (default: 1)
FREE_DAILY_PICK_LIMIT=1

# Optional — Path to the SQLite database file (default: betlab_picks.db)
DISCORD_DB_PATH=betlab_picks.db

# Optional — Set to true to log picks without actually posting to Discord
BOT_DRY_RUN=false
